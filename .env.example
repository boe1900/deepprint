# Required before the first login. If left empty, the login page will show bootstrap guidance instead of a usable sign-in form.
DEEPPRINT_INITIAL_ADMIN_USERNAME=admin
DEEPPRINT_INITIAL_ADMIN_PASSWORD=
DEEPPRINT_INITIAL_ADMIN_EMAIL=
DEEPPRINT_INITIAL_ADMIN_DISPLAY_NAME=

# CUPS admin account used by the bundled hanxi/cups container.
CUPSADMIN=print
CUPSPASSWORD=print

# Host ports exposed by Docker Compose.
DEEPPRINT_CUPS_PORT=631
DEEPPRINT_SERVER_PORT=17801
DEEPPRINT_WEB_PORT=8080

# Data and rendering. Keep defaults unless you know you need to change them.
DEEPPRINT_DATABASE_URL=sqlite:///data/deepprint.db
DEEPPRINT_RENDER_ENGINE=typst
# DeepPrint-managed Typst assets. In Docker these live under the persisted /data volume.
DEEPPRINT_TYPST_LOCAL_PACKAGES_ROOT=/data/typst/packages
DEEPPRINT_TYPST_PREVIEW_CACHE_ROOT=/data/cache/typst
DEEPPRINT_TYPST_FONTS_ROOT=/data/typst/fonts

# Advanced auth/session settings. Usually leave unset.
# DEEPPRINT_AUTH_SESSION_COOKIE_NAME=deepprint_session
# DEEPPRINT_AUTH_SESSION_TTL_SEC=604800
# DEEPPRINT_AUTH_COOKIE_SECURE=false
